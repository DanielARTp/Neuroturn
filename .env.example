# ══════════════════════════════════════════════════════════
#  NeuroTurn — Variables de entorno
#  Copia este archivo como ".env" y ajusta los valores
# ══════════════════════════════════════════════════════════

# Puerto del servidor
PORT=3002

# ─── SQL Server ────────────────────────────────────────────
# LocalDB (lo que usas ahora):
DB_SERVER=(localdb)\PANACEA-DIDACTI

# SQL Server Express local:
# DB_SERVER=.\SQLEXPRESS

# SQL Server en otro PC de la red:
# DB_SERVER=192.168.1.10\SQLEXPRESS

# Nombre de la base de datos
DB_NAME=Neuroturn

# ─── Seguridad JWT ─────────────────────────────────────────
# IMPORTANTE: Cambia esto antes de usar en producción.
# Genera un secreto seguro con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia_esto_por_una_cadena_muy_larga_y_aleatoria_en_produccion
